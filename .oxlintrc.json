{
    "$schema": "./ui/node_modules/oxlint/configuration_schema.json",
    "plugins": ["import", "typescript", "vue", "unicorn", "oxc", "promise"],
    "options": {
        "typeCheck": true,
        "typeAware": true
    },
    "rules": {
        "no-unused-vars": "off",
        "no-empty-file": "off"
    },
    "ignorePatterns": ["**/dist/*.*", "**/node_modules/**/*.*", "dokie.html"]
}
