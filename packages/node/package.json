{
    "name": "@mergehez/dokie-node",
    "version": "0.1.2",
    "description": "A Node.js package for serving the Dokie API documentation UI across generic servers, Express, Fastify, and Hono.",
    "license": "MIT",
    "author": "mergehez",
    "type": "module",
    "main": "./dist/index.cjs",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.mts",
    "exports": {
        ".": {
            "types": "./dist/index.d.mts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.cjs"
        }
    },
    "files": [
        "dist",
        "assets",
        "README.md",
        "LICENSE"
    ],
    "sideEffects": false,
    "engines": {
        "node": ">=18"
    },
    "homepage": "https://github.com/mergehez/dokie/tree/main/packages/node",
    "bugs": {
        "url": "https://github.com/mergehez/dokie/issues"
    },
    "publishConfig": {
        "access": "public"
    },
    "keywords": [
        "openapi",
        "swagger",
        "swagger-ui",
        "api",
        "api-docs",
        "api-client",
        "documentation",
        "dokie",
        "openapi-ui",
        "rest-client",
        "node",
        "http",
        "express",
        "fastify",
        "hono",
        "nextjs",
        "nuxt",
        "remix",
        "astro",
        "fetch"
    ],
    "scripts": {
        "build": "oxfmt --write && oxfmt && tsdown",
        "test": "bun test"
    },
    "devDependencies": {
        "@types/bun": "^1.3.14",
        "@types/node": "^26.0.1",
        "tsdown": "^0.22.3",
        "typescript": "^6.0.3"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/mergehez/dokie.git",
        "directory": "packages/node"
    }
}
